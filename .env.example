# LeadForge Digital — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ---- Server ----
PORT=3000
NODE_ENV=production

# ---- Email (SMTP) ----
# Use Gmail, SendGrid, Mailgun, Postmark, etc.
# For Gmail: enable 2FA and create an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ---- Notifications ----
# Where to send new lead emails (your inbox)
NOTIFY_EMAIL=leads@youragency.com

# ---- Optional: Webhook forwarding ----
# Send leads to Zapier, Make.com, CRM, or Slack
# WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/yyyyy

# ---- Security ----
# Restrict CORS to your domain in production
ALLOWED_ORIGIN=https://leadforgedigital.com

# ---- Analytics (add to index.html) ----
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# META_PIXEL_ID=XXXXXXXXXXXXXXXXX
